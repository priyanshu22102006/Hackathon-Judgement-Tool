# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/hackathon-monitor

# Server – must match the proxy port in frontend/vite.config.js
PORT=5001

# GitHub Webhook Secret (shared secret you set when creating the webhook)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: GitHub Personal Access Token (raises API rate limit from 60 → 5000 req/hr)
# Without this, syncing large repos or many teams may hit GitHub's unauthenticated limit.
# Create one at https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# IP Geolocation – uses geoip-lite (offline) by default.
# For production you can plug in ipinfo.io / ipapi.co etc.
# GEO_API_KEY=optional_api_key
